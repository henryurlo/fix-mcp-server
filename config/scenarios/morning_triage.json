  "title": "Morning Triage \u2014 Pre-Market Health Sweep",
  "severity": "critical",
  "estimated_minutes": 25,
  "categories": [
    "session",
    "orders",
    "reference_data"
  ],
  "difficulty": "beginner",
  "runbook": {
    "narrative": "It's 06:15 ET. The trading desk opens in 2 hours. ARCA is completely down from a Saturday maintenance failover. 12 orders are stuck on it, 3 of them institutional with SLA clocks ticking. On top of that, ACME has a ticker rename to ACMX effective today, and there are unknown ZEPH IPO orders. You need to fix everything before the 09:30 bell.",
    "steps": [
      {
        "step": 1,
        "title": "Check All FIX Sessions",
        "narrative": "Get a full view of every exchange connection. Confirm ARCA is down and other venues are healthy.",
        "tool": "check_fix_sessions",
        "tool_args": {},
        "expected": "ARCA shows down, NYSE/BATS/IEX show active"
      },
      {
        "step": 2,
        "title": "Identify Stuck ARCA Orders",
        "narrative": "Find all orders with venue_down flag from ARCA. The institutional ones with SLA timers are your priority.",
        "tool": "query_orders",
        "tool_args": {
          "venue": "ARCA"
        },
        "expected": "12 stuck orders found, 3+ institutional with SLA risk"
      },
      {
        "step": 3,
        "title": "Attempt ARCA Reconnection",
        "narrative": "Try to reconnect the ARCA session before resorting to workarounds.",
        "tool": "fix_session_issue",
        "tool_args": {
          "venue": "ARCA",
          "action": "reconnect"
        },
        "expected": "ARCA reconnects or reconnection fails requiring escalation"
      },
      {
        "step": 4,
        "title": "Check Reference Data \u2014 ACME Ticker Rename",
        "narrative": "Verify the ACME to ACMX corporate action is properly configured in the reference store.",
        "tool": "check_ticker",
        "tool_args": {
          "symbol": "ACME"
        },
        "expected": "ACME shows pending rename to ACMX effective today"
      },
      {
        "step": 5,
        "title": "Load Missing ZEPH Symbol",
        "narrative": "The IPO symbol ZEPH is not in the reference store. Load it so pending orders can proceed.",
        "tool": "load_ticker",
        "tool_args": {
          "symbol": "ZEPH",
          "cusip": "987456123",
          "name": "Zephyr Corp",
          "listing_exchange": "NASDAQ"
        },
        "expected": "ZEPH loaded, 2 pending orders released"
      },
      {
        "step": 6,
        "title": "Run Pre-Market Health Check",
        "narrative": "Final sweep to confirm all systems go before the opening bell.",
        "tool": "run_premarket_check",
        "tool_args": {},
        "expected": "All green, ready for 09:30 open"
      }
    ]
  },
  "hints": {
    "key_problems": [
      "ARCA FIX session is down from Saturday maintenance \u2014 12 orders stuck, 3 institutional with active SLA timers",
      "23 orders on ACME symbol have stale_ticker flag \u2014 corporate action ACME\u2192ACMX effective today",
      "2 orders on ZEPH IPO symbol fail because symbol is not loaded in reference store"
    ],
    "flag_meanings": {
      "venue_down": "Session is disconnected. Orders queued here will not reach the exchange. Try reconnecting first, then release stuck orders.",
      "stale_ticker": "Symbol has pending rename. Orders with stale symbol will be rejected at the exchange. Check corporate actions and update.",
      "symbol_not_loaded": "Symbol is not in the reference store. Use load_ticker to add it.",
      "manual_review_required": "Order needs human judgment \u2014 likely a special case or complex dependency."
    },
    "diagnosis_path": "Start by checking all FIX sessions to confirm the scope. ARCA down is the critical blocker. Then check reference data for the ACME rename and missing ZEPH symbol.",
    "common_mistakes": [
      "Trying to reroute ARCA orders to another venue \u2014 this bypasses the root cause. Reconnect first.",
      "Missing the ACME corporate action \u2014 stale tickers cause silent rejections at the exchange.",
      "Ignoring the ZEPH symbol_not_loaded orders \u2014 they are blocked until the symbol is added."
    ]
  },
  "success_criteria": [
    "All FIX sessions show active status",
    "No orders have venue_down flag",
    "ACME ticker has been renamed to ACMX via update_ticker",
    "ZEPH symbol is loaded in reference store",
