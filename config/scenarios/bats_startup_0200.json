        "narrative": "If reconnect fails due to sequence mismatch, reset_sequence to acknowledge NewSeqNo=1.",
        "tool": "fix_session_issue",
        "tool_args": {
          "venue": "BATS",
          "action": "reset_sequence"
        },
        "expected": "BATS sequence reset to 1, Logon should succeed"
      },
      {
