  "runbook": {
    "narrative": "It's 10:32 AM. NYSE latency jumped from 3ms to 180ms due to a Mahwah co-location route flap. NoC ticket #44827 is open. 14 orders are stuck in the NYSE queue unacknowledged for 8-15 minutes, 3 are institutional with SLA clocks running. The smart order router diverted 10 orders to BATS, but 2 carry listing-venue-required mandates and CANNOT be rerouted. ARCA and IEX are healthy.",
    "steps": [
      {
        "step": 1,
        "title": "Confirm NYSE Degradation",
        "narrative": "Heartbeat NYSE to confirm the latency spike. You should see RTT around 180ms vs normal 2-4ms.",
        "tool": "session_heartbeat",
        "tool_args": {
          "venue": "NYSE"
        },
        "expected": "NYSE confirms 180ms latency, status degraded"
      },
      {
        "step": 2,
        "title": "Full Session Diagnostic",
        "narrative": "Dump NYSE session state \u2014 check sequence numbers, error counts, and message backlog.",
        "tool": "dump_session_state",
        "tool_args": {
          "venue": "NYSE"
        },
        "expected": "Sequence gap detected, elevated error count, seq_backlog present"
      },
      {
        "step": 3,
        "title": "Assess Stuck Orders",
        "narrative": "Show NYSE orders. The institutional ones with listing_venue_required need special handling \u2014 they cannot be rerouted.",
        "tool": "query_orders",
        "tool_args": {
          "venue": "NYSE"
        },
        "expected": "14 stuck orders, 2 with listing_venue_required mandate"
      },
      {
        "step": 4,
        "title": "Attempt Session Fix",
        "narrative": "Try reconnecting the NYSE session. If NoC resolved the route flap, a fresh logon may restore normal latency.",
        "tool": "fix_session_issue",
        "tool_args": {
          "venue": "NYSE",
          "action": "reconnect"
        },
        "expected": "NYSE latency drops below 10ms, status returns to active"
      },
      {
        "step": 5,
        "title": "Release Stuck Orders",
        "narrative": "After reconnection, release the stuck orders. Watch for listing_venue_required orders \u2014 they must stay on NYSE.",
        "tool": "release_stuck_orders",
        "tool_args": {},
        "expected": "All stuck orders released, SLA timers cleared"
      },
      {
        "step": 6,
        "title": "Verify Full Recovery",
        "narrative": "Confirm NYSE is back to normal latency and orders are flowing. Heartbeat should show <10ms.",
        "tool": "session_heartbeat",
        "tool_args": {
          "venue": "NYSE"
        },
        "expected": "NYSE latency <10ms, status active, no sequence gaps"
      }
