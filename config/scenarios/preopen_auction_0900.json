  "runbook": {
    "narrative": "It's 09:02 AM. The opening cross is in 28 minutes. 6 institutional MOO orders for NVDA worth $18.2M are submitting into an unverified opening imbalance. NYSE published a 2.1M-share sell imbalance but the IEX imbalance feed has been stale since 08:45. On top of that, 4 orders carry TimeInForce=GTC instead of the required opening auction TIF \u2014 they will rest as day orders instead of participating in the cross.",
    "steps": [
      {
        "step": 1,
        "title": "Check IEX Feeds",
        "narrative": "IEX is degraded \u2014 verify if the imbalance feed is stale and when it last updated.",
        "tool": "check_fix_sessions",
        "tool_args": {},
        "expected": "IEX shows degraded with stale feed"
      },
      {
        "step": 2,
        "title": "Review MOO Orders",
        "narrative": "Find all MOO orders and identify which ones carry the wrong TimeInForce flag.",
        "tool": "query_orders",
        "tool_args": {},
        "expected": "6 MOO orders found, 4 carrying wrong_time_in_force"
      },
      {
        "step": 3,
        "title": "Fix Wrong TimeInForce Orders",
        "narrative": "Identify GTC orders that should be MOO for the opening cross. These need to be modified before 09:30.",
        "tool": "validate_orders",
        "tool_args": {},
        "expected": "4 orders identified with wrong_time_in_force flag"
      },
      {
        "step": 4,
        "title": "Verify Imbalance Reconciliation",
        "narrative": "After checking sessions, confirm NYSE and IEX imbalance feeds are reconciled before the open.",
        "tool": "run_premarket_check",
        "tool_args": {},
        "expected": "Imbalance feeds reconciled or flagged for manual review"
      }
    ]
  },
